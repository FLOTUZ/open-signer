# ─── Servidor ─────────────────────────────────────────────────────────────────
DOMAIN=localhost
PORT=5000
NODE_ENV=production # en producción la comprobación del efirmas del sat es estricta

# ─── Crtificados Root del SAT ───────────────────────────────────────────────────
SAT_CERTS_HOST_DIR=./certs/sat
SAT_CERTS_HASH_FILE=./certs/sat-certs.sha256

# --- CONFIGURACIÓN DE FIRMA Y REVOCACIÓN (SAT) ---
# Directorio donde se encuentran los certificados Raíz/Intermedios del SAT
SAT_CERTS_DIR="/app/certs/sat"

# Modo del Simulador de Verificación de Revocación (Sólo Desarrollo)
# Posibles valores: production, mock_good, mock_revoked, mock_timeout, mock_sat_down, disabled
# En producción DEBE ser "production" o simplemente no existir.
SAT_REVOCATION_CHECK_MODE="production"

# Modo del Simulador de Verificación de Revocación (Sólo Desarrollo)
# Posibles valores: production, mock_good, mock_revoked, mock_timeout, mock_sat_down, disabled
# En producción DEBE ser "production" o simplemente no existir.
SAT_REVOCATION_CHECK_MODE="production"


# ─── Base de Datos ─────────────────────────────────────────────────────────────
# Dentro del contenedor Docker usa host.docker.internal para alcanzar Postgres local.
# En producción (AWS RDS) reemplaza con la URL de tu instancia RDS.
DATABASE_URL="postgresql://postgres:[POSTGRESQL_PASSWORD]@host.docker.internal:5432/opensigner?schema=public"

# ─── JWT / Token de Sesión ─────────────────────────────────────────────────────
# Clave secreta para firmar los tokens HMAC-SHA256 del panel web y los tokens
# temporales de descarga de documentos. Usa un string aleatorio largo en producción.
JWT_SECRET=opensigner-local-fallback-token-secret-key-98765

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
# Si estas variables están vacías el sistema usa almacenamiento local (./uploads).
# Cuando estén configuradas, los documentos se suben a S3 y las URLs de descarga
# son presigned URLs nativas de AWS con TTL de 15 minutos.

# Región donde vive el bucket (ej. us-east-1, sa-east-1)
AWS_REGION=

# Nombre exacto del bucket S3 (ej. opensigner-prod)
AWS_S3_BUCKET=

# Credenciales del usuario IAM que tiene acceso al bucket.
# ¡NUNCA subas estos valores a un repositorio público!
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Almacenamiento Local (fallback sin S3) ────────────────────────────────────
LOCAL_STORAGE_PATH="./uploads"
